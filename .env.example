# Copy to .env.local for dev, or set these on Railway for the `web` service.

# Required in production — the single passphrase that gates the whole app.
PASSCODE=

# Required to enable the Claude tiers (haiku/sonnet/opus/fable) — the
# primary engine. Model IDs are fixed in lib/engines.ts, not configured here.
ANTHROPIC_API_KEY=

# The Ollama service (local, experimental — see README "Local model reality
# check"). On Railway private networking:
OLLAMA_URL=http://ollama.railway.internal:11434
OLLAMA_MODEL=qwen3.5:4b

# Where profile + history live. On Railway: the volume mount path.
DATA_DIR=/data

# Optional — enables GET /api/warm, which forces the local model into memory
# ahead of real traffic (a scheduler or a manual curl). Not passcode-gated
# by itself; without this set, /api/warm always returns 501. See README
# "Local model reality check".
WARM_SECRET=
